{
  "name": "sistema-vida-backend",
  "version": "1.0.0",
  "description": "Backend API para Sistema VIDA - Vinculación de Información para Decisiones y Alertas Médicas",
  "main": "dist/main.js",
  "scripts": {
    "build": "npx prisma generate && tsc --noEmitOnError",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "db:generate": "npx prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed-admin": "ts-node prisma/seed-admin.ts",
    "db:seed-rbac": "ts-node src/common/seeds/rbac.seed.ts",
    "db:seed-plans": "ts-node prisma/seed-plans.ts",
    "db:seed-hospitals": "ts-node prisma/seed-hospitals.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^13.2.2",
    "@types/puppeteer": "^5.4.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "i18next": "^25.8.13",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "otpauth": "^9.5.0",
    "otplib": "^13.1.1",
    "passkit-generator": "^3.5.7",
    "puppeteer": "^24.15.0",
    "qrcode": "^1.5.4",
    "redis": "^5.10.0",
    "resend": "^6.6.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.1.0",
    "ts-node": "^10.9.2",
    "twilio": "^4.19.0",
    "typescript": "^5.3.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xmlrpc": "^1.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@simplewebauthn/types": "^12.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.21",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@types/xmlrpc": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Sistema VIDA",
  "license": "PROPRIETARY"
}
